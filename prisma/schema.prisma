generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum ReactionType {
  LIKE
  HEART
  INSIGHTFUL
  CELEBRATE
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         Role       @default(USER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  comments         Comment[]
  reactions        Reaction[]
  commentReactions CommentReaction[]

  @@index([email])
}

model Post {
  id           String     @id @default(cuid())
  slug         String     @unique
  title        String
  excerpt      String
  content      String
  coverUrl     String?
  tags         String?
  published    Boolean    @default(false)
  publishedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  comments     Comment[]
  reactions    Reaction[]

  nextPostId   String?
  nextPost     Post?      @relation("PostNextRead", fields: [nextPostId], references: [id], onDelete: SetNull)
  suggestedBy  Post[]     @relation("PostNextRead")

  @@index([slug])
  @@index([published, publishedAt])
}

model Comment {
  id         String            @id @default(cuid())
  content    String            @db.VarChar(2000)
  approved   Boolean           @default(false)
  parentId   String?
  parent     Comment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[]         @relation("CommentReplies")
  reactions  CommentReaction[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  postId     String
  post       Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestName  String?
  guestEmail String?

  @@index([postId])
  @@index([postId, approved])
}

model CommentReaction {
  id        String       @id @default(cuid())
  type      ReactionType
  createdAt DateTime     @default(now())
  commentId String
  comment   Comment      @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, type])
  @@index([commentId])
}

model SiteContent {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Highlight {
  id            String              @id @default(cuid())
  title         String
  description   String?
  type          String
  url           String?
  imageUrl      String?
  date          DateTime?
  published     Boolean             @default(true)
  order         Int                 @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  eventName     String?
  keyTakeaways  String?
  technologies  String?
  audience      String?
  impactMetrics String?
  transcript    String?
  slidesUrl     String?
  slides        HighlightSlide[]
  resources     HighlightResource[]

  @@index([published, order])
}

model HighlightSlide {
  id          String    @id @default(cuid())
  highlightId String
  highlight   Highlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)
  imageUrl    String
  caption     String?
  category    String    @default("slide")
  order       Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([highlightId, order])
}

model HighlightResource {
  id          String    @id @default(cuid())
  highlightId String
  highlight   Highlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)
  label       String
  url         String
  type        String    @default("link")
  order       Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([highlightId, order])
}

model Reaction {
  id        String       @id @default(cuid())
  type      ReactionType
  createdAt DateTime     @default(now())
  postId    String
  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
  @@index([postId])
}
