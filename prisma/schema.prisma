generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum ReactionType {
  LIKE
  HEART
  INSIGHTFUL
  CELEBRATE
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         Role       @default(USER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  comments     Comment[]
  reactions    Reaction[]

  @@index([email])
}

model Post {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  excerpt     String
  content     String
  published   Boolean    @default(false)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  comments    Comment[]
  reactions   Reaction[]

  @@index([slug])
  @@index([published, publishedAt])
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.VarChar(2000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model SiteContent {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Highlight {
  id            String              @id @default(cuid())
  title         String
  description   String?
  type          String
  url           String?
  imageUrl      String?
  date          DateTime?
  published     Boolean             @default(true)
  order         Int                 @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  eventName     String?
  keyTakeaways  String?
  technologies  String?
  audience      String?
  impactMetrics String?
  transcript    String?
  slidesUrl     String?
  slides        HighlightSlide[]
  resources     HighlightResource[]

  @@index([published, order])
}

model HighlightSlide {
  id          String    @id @default(cuid())
  highlightId String
  highlight   Highlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)
  imageUrl    String
  caption     String?
  category    String    @default("slide")
  order       Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([highlightId, order])
}

model HighlightResource {
  id          String    @id @default(cuid())
  highlightId String
  highlight   Highlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)
  label       String
  url         String
  type        String    @default("link")
  order       Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([highlightId, order])
}

model Reaction {
  id        String       @id @default(cuid())
  type      ReactionType
  createdAt DateTime     @default(now())
  postId    String
  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
  @@index([postId])
}
