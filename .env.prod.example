# PROD ENVIRONMENT — set these as environment variables in AWS Amplify (main branch)
# Use Neon "main" branch connection strings
# Do NOT commit real values — add these in the Amplify console

# Neon main branch — pooled (used at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1"

# Neon main branch — direct (used by prisma migrate deploy during build)
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Generate a DIFFERENT secret from local and qa: openssl rand -base64 32
AUTH_SECRET="replace-with-prod-specific-32-byte-secret"

NEXTAUTH_URL="https://www.rambrij.com"

NODE_ENV="production"

# No banner shown in prod (omit or set to "prod")
NEXT_PUBLIC_ENV="prod"
