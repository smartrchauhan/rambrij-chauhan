# QA ENVIRONMENT — set these as environment variables in AWS Amplify (qa branch)
# Use Neon "qa" branch connection strings
# Do NOT commit real values — add these in the Amplify console

# Neon qa branch — pooled (used at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1"

# Neon qa branch — direct (used by prisma migrate deploy during build)
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Generate a DIFFERENT secret from local and prod: openssl rand -base64 32
AUTH_SECRET="replace-with-qa-specific-32-byte-secret"

NEXTAUTH_URL="https://qa.rambrij.com"

NODE_ENV="production"

# Shows a visible QA banner on the site
NEXT_PUBLIC_ENV="qa"
